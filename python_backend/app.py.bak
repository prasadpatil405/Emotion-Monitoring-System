# Enhanced emotion analysis with realistic patterns
class EmotionFusionEngine:
    def __init__(self):
        self.emotions = ['happy', 'sad', 'angry', 'fearful', 'surprised', 'disgusted', 'neutral', 'excited', 'calm', 'stressed']
        self.adolescent_patterns = {
            'happy': {'base_confidence': 0.8, 'variability': 0.15},
            'sad': {'base_confidence': 0.75, 'variability': 0.2},
            'angry': {'base_confidence': 0.85, 'variability': 0.1},
            'fearful': {'base_confidence': 0.7, 'variability': 0.25},
            'surprised': {'base_confidence': 0.9, 'variability': 0.05},
            'disgusted': {'base_confidence': 0.8, 'variability': 0.15},
            'neutral': {'base_confidence': 0.6, 'variability': 0.3},
            'excited': {'base_confidence': 0.85, 'variability': 0.1},
            'calm': {'base_confidence': 0.75, 'variability': 0.2},
            'stressed': {'base_confidence': 0.8, 'variability': 0.15}
        }
        
    def fuse_emotions(self, facial_emotion=None, voice_emotion=None, text_emotion=None):
        sources = []
        weights = []
        
        if facial_emotion:
            sources.append(facial_emotion)
            weights.append(0.4)  # Facial gets highest weight
        if voice_emotion:
            sources.append(voice_emotion)
            weights.append(0.35)  # Voice gets medium weight
        if text_emotion:
            sources.append(text_emotion)
            weights.append(0.25)  # Text gets lowest weight
            
        if not sources:
            # Return a neutral default
            return {
                "emotion": "neutral",
                "confidence": 60,
                "sources": {},
                "timestamp": self.get_timestamp()
            }
            
        # Simple fusion: take the emotion with highest weighted confidence
        best_emotion = None
        best_score = 0
        
        for i, source in enumerate(sources):
            emotion = source.get('emotion', 'neutral')
            confidence = source.get('confidence', 50)
            weighted_score = confidence * weights[i]
            
            if weighted_score > best_score:
                best_score = weighted_score
                best_emotion = emotion
                
        # Apply adolescent adjustments
        if best_emotion and best_emotion in self.adolescent_patterns:
            pattern = self.adolescent_patterns[best_emotion]
            base_conf = pattern['base_confidence']
            variability = pattern['variability']
            
            # Add some realistic variability
            confidence_adjustment = random.uniform(-variability, variability)
            final_confidence = max(20, min(95, (base_conf + confidence_adjustment) * 100))
        else:
            final_confidence = max(20, min(95, best_score))
            
        return {
            "emotion": best_emotion or "neutral",
            "confidence": int(final_confidence),
            "sources": {
                "facial": facial_emotion,
                "voice": voice_emotion, 
                "text": text_emotion
            },
            "timestamp": self.get_timestamp()
        }
    
    def analyze_autism_patterns(self, sessions):
        if not sessions:
            return {"patterns": [], "recommendations": []}
            
        # Analyze patterns for autism-specific traits
        emotion_counts = {}
        total_sessions = len(sessions)
        
        for session in sessions:
            emotion = session.get('fused_emotion', 'neutral')
            emotion_counts[emotion] = emotion_counts.get(emotion, 0) + 1
            
        patterns = []
        recommendations = []
        
        # Check for emotional intensity patterns
        if emotion_counts.get('angry', 0) / total_sessions > 0.3:
            patterns.append("High frequency of anger responses detected")
            recommendations.append("Consider calming activities like deep breathing exercises")
            
        if emotion_counts.get('fearful', 0) / total_sessions > 0.25:
            patterns.append("Elevated anxiety patterns observed")
            recommendations.append("Practice gradual exposure to new situations")
            
        if emotion_counts.get('neutral', 0) / total_sessions > 0.6:
            patterns.append("Limited emotional expression range")
            recommendations.append("Engage in emotion identification exercises")
            
        return {
            "patterns": patterns,
            "recommendations": recommendations,
            "emotion_distribution": emotion_counts,
            "analysis_date": self.get_timestamp()
        }
    
    def get_timestamp(self):
        return datetime.now().isoformat()

class FacialEmotionDetector:
    def __init__(self):
        self.emotions = ['happy', 'sad', 'angry', 'fearful', 'surprised', 'disgusted', 'neutral']
        
    def analyze_emotion(self, image_data):
        # Simulate facial emotion detection
        # In a real implementation, this would use OpenCV and CNN models
        emotion = random.choice(self.emotions)
        confidence = random.uniform(60, 95)
        
        # Add some realistic emotion patterns
        time_of_day = datetime.now().hour
        if 6 <= time_of_day <= 9:  # Morning
            if random.random() < 0.3:
                emotion = random.choice(['calm', 'neutral', 'happy'])
        elif 12 <= time_of_day <= 14:  # Lunch
            if random.random() < 0.4:
                emotion = random.choice(['happy', 'excited', 'neutral'])
        elif 18 <= time_of_day <= 22:  # Evening
            if random.random() < 0.3:
                emotion = random.choice(['tired', 'calm', 'stressed'])
                
        return {
            "emotion": emotion,
            "confidence": int(confidence),
            "landmarks": {
                "face_detected": True,
                "face_count": 1,
                "quality_score": random.uniform(0.7, 1.0)
            },
            "timestamp": datetime.now().isoformat()
        }

class VoiceEmotionAnalyzer:
    def __init__(self):
        self.emotions = ['happy', 'sad', 'angry', 'fearful', 'excited', 'calm', 'stressed']
        
    def analyze_emotion(self, audio_data):
        # Simulate voice emotion analysis
        # In a real implementation, this would use Librosa and audio ML models
        emotion = random.choice(self.emotions)
        confidence = random.uniform(55, 90)
        
        return {
            "emotion": emotion,
            "confidence": int(confidence),
            "features": {
                "pitch_mean": random.uniform(80, 300),
                "energy_level": random.uniform(0.1, 0.9),
                "speaking_rate": random.uniform(100, 200),
                "audio_quality": random.uniform(0.6, 1.0)
            },
            "timestamp": datetime.now().isoformat()
        }

class TextSentimentAnalyzer:
    def __init__(self):
        self.positive_words = ['good', 'great', 'awesome', 'happy', 'love', 'amazing', 'wonderful', 'excited']
        self.negative_words = ['bad', 'terrible', 'hate', 'sad', 'angry', 'awful', 'horrible', 'stressed']
        self.neutral_words = ['okay', 'fine', 'normal', 'usual', 'maybe', 'think', 'probably']
        
    def analyze_sentiment(self, text):
        if not text:
            return {"sentiment": "neutral", "confidence": 50, "analysis": {}}
            
        text_lower = text.lower()
        words = text_lower.split()
        
        positive_count = sum(1 for word in words if word in self.positive_words)
        negative_count = sum(1 for word in words if word in self.negative_words)
        neutral_count = sum(1 for word in words if word in self.neutral_words)
        
        total_emotional_words = positive_count + negative_count + neutral_count
        
        if total_emotional_words == 0:
            sentiment = "neutral"
            confidence = 60
        elif positive_count > negative_count:
            sentiment = "positive"
            confidence = min(95, 60 + (positive_count / len(words)) * 35)
        elif negative_count > positive_count:
            sentiment = "negative" 
            confidence = min(95, 60 + (negative_count / len(words)) * 35)
        else:
            sentiment = "neutral"
            confidence = 70
            
        return {
            "sentiment": sentiment,
            "confidence": int(confidence),
            "analysis": {
                "positive_words": positive_count,
                "negative_words": negative_count,
                "neutral_words": neutral_count,
                "text_length": len(words),
                "emotional_intensity": total_emotional_words / len(words) if words else 0
            },
            "timestamp": datetime.now().isoformat()
        }

